@using FitOSC.Services.State
@using FitOSC.Services.Treadmill
@inject AppStateService AppStateService
@implements IDisposable

<div class="treadmill-display-metrics @((AppStateInfo?.TreadmillState != TreadmillState.Stopped && 
                                         AppStateInfo?.TreadmillState != TreadmillState.Unknown ) ? "visible" : "")">
    <KPIBox Property="TreadmillTelemetryProperty.InstantaneousPace" ValueFormat="0.0" />
    <KPIBox Property="TreadmillTelemetryProperty.TotalDistance" ValueFormat="0.00" />
    <DurationInterface />
    <KPIBox Property="TreadmillTelemetryProperty.Calories" ValueFormat="0" />
    <KPIBox Property="TreadmillTelemetryProperty.HeartRate" ValueFormat="0" />
</div>
@code {
    private AppStateInfo? AppStateInfo { get; set; }
    private TreadmillState _previousState = TreadmillState.Unknown;

    protected override void OnInitialized()
    {
        AppStateService.AppStateUpdated += HandleAppStateUpdated;
    }

    private void HandleAppStateUpdated(AppStateInfo data)
    {
        var previousState = AppStateInfo?.TreadmillState ?? TreadmillState.Unknown;
        AppStateInfo = data;

        // Only trigger re-render if state changed (affects visibility CSS class)
        if (data.TreadmillState != previousState)
        {
            InvokeAsync(StateHasChanged);
        }
    }

    // Prevent unnecessary re-renders - child KPIBox components handle their own updates
    protected override bool ShouldRender()
    {
        var currentState = AppStateInfo?.TreadmillState ?? TreadmillState.Unknown;
        var shouldRender = currentState != _previousState;
        _previousState = currentState;
        return shouldRender;
    }

    public void Dispose()
    {
        AppStateService.AppStateUpdated -= HandleAppStateUpdated;
    }
}