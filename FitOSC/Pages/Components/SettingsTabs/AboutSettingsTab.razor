@code {
    private bool _isChecking = false;
    private bool _hasChecked = false;

    protected override void OnInitialized()
    {
        UpdateCheckService.UpdateAvailableChanged += HandleUpdateAvailableChanged;
    }

    private void HandleUpdateAvailableChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task CheckForUpdates()
    {
        _isChecking = true;
        _hasChecked = false;
        StateHasChanged();

        try
        {
            await UpdateCheckService.CheckForUpdatesManuallyAsync();
            _hasChecked = true;
        }
        finally
        {
            _isChecking = false;
            StateHasChanged();
        }
    }

    private void OpenUpdateUrl()
    {
        if (!string.IsNullOrEmpty(UpdateCheckService.ReleaseUrl))
        {
            try
            {
                System.Diagnostics.Process.Start(new System.Diagnostics.ProcessStartInfo
                {
                    FileName = UpdateCheckService.ReleaseUrl,
                    UseShellExecute = true
                });
            }
            catch
            {
                // Silently fail if we can't open the browser
            }
        }
    }

    public void Dispose()
    {
        UpdateCheckService.UpdateAvailableChanged -= HandleUpdateAvailableChanged;
    }
}
