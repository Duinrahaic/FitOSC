@using System.Reflection
@using FitOSC.Services
@inject UpdateCheckService UpdateCheckService
@implements IDisposable

<div class="settings-section">
    <div class="settings-header">
        <h3>FitOSC</h3>
        <div class="header-version-controls">
            <span class="header-version">Version @UpdateCheckService.CurrentVersion</span>
            <button class="btn-secondary btn-small" @onclick="CheckForUpdates" disabled="@_isChecking">
                <i class="fa-solid fa-rotate @(_isChecking ? "fa-spin" : "")"></i>
            </button>
            @if (UpdateCheckService.UpdateAvailable)
            {
                <button class="btn-primary btn-small" @onclick="OpenUpdateUrl">
                    <i class="fa-solid fa-download"></i>
                    <span>Update</span>
                </button>
            }
            else if (!_isChecking)
            {
                <span class="update-status-badge">
                    <i class="fa-solid fa-check-circle"></i>
                    <span>Up to date</span>
                </span>
            }
        </div>
    </div>

    <div class="settings-item">
        <div class="about-links">
            <a href="https://github.com/duinrahaic/FitOSC" target="_blank" class="about-link">
                <i class="fa-brands fa-github"></i>
                <span>GitHub</span>
            </a>
            <a href="https://me.duinrahaic.app/fitosc" target="_blank" class="about-link">
                <i class="fa-solid fa-book"></i>
                <span>User Guide</span>
            </a>
        </div>
    </div>
</div>

